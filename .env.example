# ==============================================================================
# Tutor Hub - Environment Configuration Template
# ==============================================================================

# ------------------------------------------------------------------------------
# 1. Database Configuration (MariaDB)
# ------------------------------------------------------------------------------
# The root password for MariaDB. Automatically generated by gen-passwords.sh
DB_PASSWORD=placeholder_db_password
DB_DATABASE=tutor_hub

# ------------------------------------------------------------------------------
# 2. Tutor Hub Application Configuration
# ------------------------------------------------------------------------------
# Secret key used for Better Auth. Automatically generated by gen-passwords.sh
BETTER_AUTH_SECRET=placeholder_better_auth_secret

# The external URL of the web app. Update in production.
BETTER_AUTH_URL=http://localhost:3000

# ------------------------------------------------------------------------------
# 3. Jitsi Meet Integration (App & Videobridge)
# ------------------------------------------------------------------------------
# The domain/IP used by clients to access the Jitsi Meet web interface.
# Update in production (e.g. meet.yourdomain.com).
JITSI_DOMAIN=localhost:8443

# The JWT App ID (must match Jitsi configuration)
JITSI_APP_ID=tutor_hub

# Secret key used to sign Jitsi JWT tokens. Automatically generated by gen-passwords.sh
JITSI_JWT_SECRET=placeholder_jitsi_jwt_secret

# Jitsi release version (default: stable)
JITSI_IMAGE_VERSION=stable

# Jitsi Internal Configuration Directory
JITSI_CONFIG_DIR=./jitsi-meet-cfg

# ------------------------------------------------------------------------------
# 4. Jitsi Meet Internal Authentication (Automatically generated)
# ------------------------------------------------------------------------------
# Internal XMPP component passwords used by Jitsi services to talk to each other.
JICOFO_COMPONENT_SECRET=placeholder_jicofo_component_secret
JICOFO_AUTH_PASSWORD=placeholder_jicofo_auth_password
JVB_AUTH_PASSWORD=placeholder_jvb_auth_password

# ------------------------------------------------------------------------------
# 5. Email Notification Configuration (SMTP)
# ------------------------------------------------------------------------------
SMTP_HOST=smtp.mailtrap.io
SMTP_PORT=587
SMTP_USER=your_smtp_user
SMTP_PASS=your_smtp_password
SMTP_FROM_NAME="Tutor Hub Classroom"

# ------------------------------------------------------------------------------
# 6. Object Storage Configuration (S3 Compatible - Optional)
# ------------------------------------------------------------------------------
# Leave blank to fall back to storing uploads inside the local app container storage.
S3_ENDPOINT=
S3_ACCESS_KEY_ID=
S3_SECRET_ACCESS_KEY=
S3_BUCKET_NAME=
S3_PUBLIC_URL=
